{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./.dev.vars)",
      "Read(./.dev.vars.*)",
      "Read(./**/.dev.vars)",
      "Read(./**/.dev.vars.*)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./**/.env)",
      "Edit(./**/.env.*)",
      "Edit(./.dev.vars)",
      "Edit(./.dev.vars.*)",
      "Edit(./**/.dev.vars)",
      "Edit(./**/.dev.vars.*)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./**/.env)",
      "Write(./**/.env.*)",
      "Write(./.dev.vars)",
      "Write(./.dev.vars.*)",
      "Write(./**/.dev.vars)",
      "Write(./**/.dev.vars.*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "denyRead": [
        ".env",
        ".env.*",
        "**/.env",
        "**/.env.*",
        ".dev.vars",
        ".dev.vars.*",
        "**/.dev.vars",
        "**/.dev.vars.*"
      ],
      "denyWrite": [
        ".env",
        ".env.*",
        "**/.env",
        "**/.env.*",
        ".dev.vars",
        ".dev.vars.*",
        "**/.dev.vars",
        "**/.dev.vars.*"
      ]
    }
  }
}
