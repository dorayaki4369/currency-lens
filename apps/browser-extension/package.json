{
  "name": "browser-extension",
  "description": "Currency Lens Browser Extension",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare",
    "wxt": "wxt"
  },
  "dependencies": {
    "@cl/currency": "workspace:*",
    "@floating-ui/react-dom": "^2.1.6",
    "cryptocurrency-icons": "^0.18.1",
    "flag-icons": "^7.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.11",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "@cl/eslint-config": "workspace:*",
    "@tailwindcss/vite": "^4.1.11",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "@wxt-dev/auto-icons": "^1.0.2",
    "@wxt-dev/module-react": "^1.1.3",
    "eslint": "^9.39.1",
    "wxt": "^0.20.13"
  }
}
