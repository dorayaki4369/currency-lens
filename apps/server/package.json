{
  "name": "@cl/server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "CLOUDFLARE_LOAD_DEV_VARS_FROM_DOT_ENV=false WRANGLER_SEND_METRICS=false WRANGLER_WRITE_LOGS=false wrangler dev --env-file wrangler.no-secrets --test-scheduled",
    "typegen": "CLOUDFLARE_LOAD_DEV_VARS_FROM_DOT_ENV=false WRANGLER_SEND_METRICS=false WRANGLER_WRITE_LOGS=false wrangler types --env-file wrangler.no-secrets --env-interface CloudflareBindings",
    "build": "CLOUDFLARE_LOAD_DEV_VARS_FROM_DOT_ENV=false WRANGLER_SEND_METRICS=false WRANGLER_WRITE_LOGS=false wrangler build --env-file wrangler.no-secrets",
    "deploy": "CLOUDFLARE_LOAD_DEV_VARS_FROM_DOT_ENV=false WRANGLER_SEND_METRICS=false WRANGLER_WRITE_LOGS=false wrangler deploy --env-file wrangler.no-secrets --minify",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cl/oxr": "workspace:*",
    "hono": "^4.12.30",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "wrangler": "^4.112.0"
  }
}
