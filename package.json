{
  "name": "currency-lens",
  "version": "0.1.0",
  "private": true,
  "description": "A browser extension for converting the currency to your favorite currency.",
  "license": "MIT",
  "author": {
    "name": "Ryuya Hirayama",
    "email": "ryuya.hirayama@dryk.net"
  },
  "main": "index.js",
  "scripts": {
    "dev": "vp run --no-cache -r dev",
    "ext": "pnpm -C apps/browser-extension",
    "srv": "pnpm -C apps/server",
    "pkg:cur": "pnpm -C packages/currency",
    "pkg:oxr": "pnpm -C packages/oxr",
    "build": "vp run -r build",
    "check": "vp check",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "lint": "vp lint",
    "test": "vp test --run",
    "test:coverage": "vp test --run --coverage",
    "typecheck": "vp check --no-fmt --no-lint",
    "validate": "vp check && vp test --run && vp run -r build"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "oxlint-tsgolint": "^0.25.0",
    "typescript": "^7.0.2",
    "vite-plus": "^0.2.5",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24 <25",
    "npm": "npm not allowed",
    "pnpm": ">=11.13.0",
    "yarn": "yarn not allowed"
  },
  "volta": {
    "node": "24.11.1",
    "pnpm": "11.13.0"
  },
  "packageManager": "pnpm@11.13.0"
}
